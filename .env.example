# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose which LLM backend to use: "gemini" (default) or "gemma3" (local Ollama)
LLM_PROVIDER=gemini

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Get your free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model name (default: gemini-1.5-flash)
# Other options: gemini-1.5-pro, gemini-1.0-pro
GEMINI_MODEL=gemini-1.5-flash

# ── Gemma3 via Ollama (local) ─────────────────────────────────────────────────
# Install Ollama: https://ollama.com  then run: ollama pull gemma3
OLLAMA_HOST=http://localhost:11434
GEMMA3_MODEL=gemma3

# ── Flask server ──────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
